# =========================================================================
# Winter E-commerce Platform - Root Gitignore Manifest
# =========================================================================

# -------------------------------------------------------------------------
# OS / System Files
# -------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -------------------------------------------------------------------------
# IDEs and Text Editors
# -------------------------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
*.code-workspace

# Eclipse
.metadata/
.classpath
.project
.settings/
*.launch

# NetBeans
**/nbproject/private/
**/nbbuild/
**/dist/
**/nbproject/maven-pom.xml

# Vim/Emacs temp files
*~
*.swp
*.swo

# -------------------------------------------------------------------------
# Java & Maven Exclusions (Microservices)
# -------------------------------------------------------------------------
**/target/
**/*.class
**/*.jar
**/*.war
**/*.nar
**/*.ear
**/*.zip
**/*.tar.gz
**/*.rar
.mvn/
.flattened-pom.xml
dependency-reduced-pom.xml

# -------------------------------------------------------------------------
# Node.js & NPM / Yarn (Frontend BFF & CDK)
# -------------------------------------------------------------------------
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# npm/yarn log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------------------------------------
# Next.js BFF Specific Exclusions
# -------------------------------------------------------------------------
frontend-bff/.next/
frontend-bff/out/
frontend-bff/build/
frontend-bff/.vercel/
frontend-bff/next-env.d.ts
*.tsbuildinfo

# -------------------------------------------------------------------------
# AWS CDK Infrastructure Exclusions
# -------------------------------------------------------------------------
infrastructure-cdk/cdk.out/
infrastructure-cdk/.cdk.staging/
# Ignore compiled JavaScript and Declaration files from TypeScript CDK source
infrastructure-cdk/**/*.js
!infrastructure-cdk/jest.config.js
infrastructure-cdk/**/*.d.ts

# -------------------------------------------------------------------------
# Credentials and Environment Configurations (Sensitive Data)
# -------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.pub
